<?xml version="1.0"?>
<!--
  fer_gz.urdf.xacro
  -
  Wraps franka_description's fer.urdf.xacro (geometry/visuals/collisions
  only - gazebo:=false, ros2_control:=false so none of its own hardware
  branches fire) and appends our own <ros2_control> block targeting
  gz_ros2_control/GazeboSimSystem, which is the plugin actually built in
  ~/gz_ros2_control_ws (confirmed present via `ros2 pkg list`), instead of
  franka_description's own gazebo:=true path (franka_ign_ros2_control,
  which is NOT installed on this machine and pulls in franka_ros2/libfranka).

  Joint names below (fer_joint1..7, fer_finger_joint1/2) come directly from
  franka_arm.ros2_control.xacro and franka_hand.xacro as inspected on this
  machine - not guessed.

  RUNTIME VERIFICATION ITEM: joint position limits below are placeholders
  copied from the well-known Franka Panda/FER limits (same kinematic arm),
  NOT read from this machine's robots/fer/joint_limits.yaml. Cross-check
  against that file before relying on these for anything beyond a first
  "does it spawn and move" smoke test:
      cat /opt/ros/humble/share/franka_description/robots/fer/joint_limits.yaml
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="fer">
  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <!-- Geometry only: no hardware/ros2_control/legacy-transmission tags emitted -->
  <xacro:include filename="/home/student/bps-project/gz_test/fer_local/fer.urdf.xacro" />
  <!-- NOTE: fer.urdf.xacro's own xacro:arg defaults already give us
       gazebo:=false, ros2_control:=false, hand:=true, ee_id:=franka_hand.
       Nothing further to pass here; if you want the bare arm without a
       gripper for this first test, add ${'hand:=false'} via a second
       xacro:arg override - see note at bottom of this file. -->

  <!-- ============================================================
       Our own gz_ros2_control hardware block
       ============================================================ -->
  <ros2_control name="FerGazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="fer_joint1">
      <command_interface name="position"><param name="min">-2.8973</param><param name="max">2.8973</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fer_joint2">
      <command_interface name="position"><param name="min">-1.7628</param><param name="max">1.7628</param></command_interface>
      <state_interface name="position"><param name="initial_value">-0.7853981633974483</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fer_joint3">
      <command_interface name="position"><param name="min">-2.8973</param><param name="max">2.8973</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fer_joint4">
      <command_interface name="position"><param name="min">-3.0718</param><param name="max">-0.0698</param></command_interface>
      <state_interface name="position"><param name="initial_value">-2.356194490192345</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fer_joint5">
      <command_interface name="position"><param name="min">-2.8973</param><param name="max">2.8973</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fer_joint6">
      <command_interface name="position"><param name="min">-0.0175</param><param name="max">3.7525</param></command_interface>
      <state_interface name="position"><param name="initial_value">1.5707963267948966</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fer_joint7">
      <command_interface name="position"><param name="min">-2.8973</param><param name="max">2.8973</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.7853981633974483</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Gripper: franka_hand.xacro's convention is finger_joint1 driven,
         finger_joint2 mimics it. RUNTIME VERIFICATION ITEM: confirm the
         mimic relationship/joint names against:
         cat /opt/ros/humble/share/franka_description/end_effectors/common/franka_hand.xacro
         If this doesn't match, drop this joint from here for now -
         it's not needed for the "move one arm joint" checkpoint. -->
    <joint name="fer_finger_joint1">
      <command_interface name="position"><param name="min">0.0</param><param name="max">0.04</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.02</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fer_finger_joint2">
      <command_interface name="position"><param name="min">0.0</param><param name="max">0.04</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.02</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <!-- RUNTIME VERIFICATION ITEM: replace with the real absolute path
           on your machine, e.g. /home/student/bps-project/gz_test/fer_gz_controllers.yaml
           $(find ...) only resolves for installed ROS packages, which
           this scratch directory is not. -->
      <parameters>/home/student/bps-project/gz_test/fer_gz_controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
