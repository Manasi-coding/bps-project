    <!-- ==================== TABLETOP OBJECTS: MANIPULATION BENCHMARK (world7) ==================== -->
    <!--
      Tabletop face : z = 0.77 m
      Safe footprint: x in [-0.46, 0.46],  y in [-0.78, -0.22]

      15 everyday objects combining every prior-world challenge in balanced
      proportions: isolated objects, touching pairs, thin/flat objects,
      partial occlusion, support relationships, and adjacent clusters.
      All poses/geometry sized so nothing intersects, floats, or leaves the
      camera FOV footprint established in world1 (FOV=1.2 rad @ 0.80 m).

      Layout summary (top-down, N = towards +y):
        Row1 (y=-0.30): bottle | cereal_box | notebook(+pen) | tissue_box | mug(+remote, touching)
        Row2 (y=-0.50): glass_jar | apple (partial occlusion by jar) | bowl(+toy_block, touching) | plate(+spoon, support) | fork (adjacent to plate)
        Row3 (y=-0.70): banana (isolated, lying flat)

      Support relationships (2): pen resting on notebook, spoon resting on plate.
      Touching/adjacent clusters: mug+remote, bowl+toy_block, plate+fork.
      Partial occlusion: apple tucked close behind glass_jar.
      Thin objects: notebook, plate, spoon, fork, pen, remote.
    -->

    <!-- BOTTLE  label=1  isolated -->
    <model name="obj_bottle">
      <static>true</static>
      <pose>-0.40 -0.30 0.88 0 0 0.2</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>0.035</radius><length>0.22</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.035</radius><length>0.22</length></cylinder></geometry>
          <material>
            <ambient>0.10 0.42 0.28 1</ambient>
            <diffuse>0.10 0.42 0.28 1</diffuse>
            <specular>0.4 0.4 0.4 1</specular>
          </material>
          <plugin filename="gz-sim-label-system" name="gz::sim::systems::Label"><label>1</label></plugin>
        </visual>
      </link>
    </model>

    <!-- CEREAL BOX  label=2  isolated -->
