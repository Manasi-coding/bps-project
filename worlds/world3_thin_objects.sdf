            <label>9</label>
          </plugin>
        </visual>
      </link>
    </model>

    <!-- SPOON  label=10  (crosses knife, raised ~3mm to sit across it, avoiding intersection) -->
    <model name="obj_spoon">
      <static>true</static>
      <pose>-0.09 -0.35 0.778 0 0 -0.4</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.18 0.025 0.006</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.18 0.025 0.006</size></box></geometry>
          <material>
            <ambient>0.72 0.72 0.76 1</ambient>
            <diffuse>0.72 0.72 0.76 1</diffuse>
            <specular>0.6 0.6 0.6 1</specular>
          </material>
          <plugin filename="gz-sim-label-system" name="gz::sim::systems::Label">
            <label>10</label>
          </plugin>
        </visual>
      </link>
    </model>

    <!-- RULER  label=11  (crossed by cable) -->
    <model name="obj_ruler">
      <static>true</static>
      <pose>-0.20 -0.70 0.7715 0 0 0.15</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.30 0.03 0.003</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.30 0.03 0.003</size></box></geometry>
          <material>
            <ambient>0.82 0.66 0.35 1</ambient>
            <diffuse>0.82 0.66 0.35 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
          <plugin filename="gz-sim-label-system" name="gz::sim::systems::Label">
            <label>11</label>
          </plugin>
        </visual>
      </link>
    </model>

    <!-- CABLE  label=12  (bent, two segments; crosses ruler, raised to ruler-top
         height at the crossing segment to avoid intersecting the ruler) -->
    <model name="obj_cable">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        <collision name="collision_seg1">
          <pose>-0.28 -0.735 0.7715 0 0 0.1</pose>
          <geometry><box><size>0.13 0.006 0.003</size></box></geometry>
        </collision>
        <visual name="visual_seg1">
          <pose>-0.28 -0.735 0.7715 0 0 0.1</pose>
          <geometry><box><size>0.13 0.006 0.003</size></box></geometry>
          <material>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.05 0.05 0.05 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
          <plugin filename="gz-sim-label-system" name="gz::sim::systems::Label">
            <label>12</label>
          </plugin>
        </visual>
        <collision name="collision_seg2">
          <pose>-0.13 -0.685 0.7745 0 0 0.6</pose>
          <geometry><box><size>0.12 0.006 0.003</size></box></geometry>
        </collision>
        <visual name="visual_seg2">
          <pose>-0.13 -0.685 0.7745 0 0 0.6</pose>
          <geometry><box><size>0.12 0.006 0.003</size></box></geometry>
          <material>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.05 0.05 0.05 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
          <plugin filename="gz-sim-label-system" name="gz::sim::systems::Label">
            <label>12</label>
          </plugin>
        </visual>
      </link>
    </model>

    <!-- CHOPSTICKS  label=13  (close parallel pair, two model instances) -->
    <model name="obj_chopstick_a">
      <static>true</static>
      <pose>-0.34 -0.36 0.773 0 1.5708 1.2</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>0.003</radius><length>0.22</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.003</radius><length>0.22</length></cylinder></geometry>
          <material>
            <ambient>0.85 0.72 0.50 1</ambient>
            <diffuse>0.85 0.72 0.50 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
          <plugin filename="gz-sim-label-system" name="gz::sim::systems::Label">
            <label>13</label>
          </plugin>
        </visual>
      </link>
    </model>

    <model name="obj_chopstick_b">
      <static>true</static>
      <pose>-0.3512 -0.3557 0.773 0 1.5708 1.2</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>0.003</radius><length>0.22</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.003</radius><length>0.22</length></cylinder></geometry>
          <material>
            <ambient>0.85 0.72 0.50 1</ambient>
            <diffuse>0.85 0.72 0.50 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
          <plugin filename="gz-sim-label-system" name="gz::sim::systems::Label">
            <label>18</label>
          </plugin>
        </visual>
      </link>
    </model>

    <!-- DRINKING STRAW  label=14 -->
    <model name="obj_straw">
      <static>true</static>
      <pose>-0.34 -0.55 0.774 0 1.5708 1.0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>0.004</radius><length>0.19</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.004</radius><length>0.19</length></cylinder></geometry>
          <material>
            <ambient>0.90 0.90 0.95 1</ambient>
            <diffuse>0.90 0.90 0.95 1</diffuse>
            <specular>0.5 0.5 0.5 1</specular>
          </material>
          <plugin filename="gz-sim-label-system" name="gz::sim::systems::Label">
            <label>14</label>
          </plugin>
        </visual>
      </link>
    </model>

    <!-- ==================== CAMERA (permanent, top-down above table) ==================== -->
    <!--
      Position : (0, -0.5, 1.57) centred above experiment table
      Pitch    : 1.5708 rad - straight down
      Height above tabletop: 1.57 - 0.77 = 0.80 m

      FIX 2 - FOV raised from 0.9 to 1.2 rad on all three sensors.
        At 0.80 m height:
          horizontal half-width  = 0.80 * tan(0.60) = 0.547 m
          vertical   half-height = 0.80 * tan(0.47) = 0.408 m  (640x480 aspect)
        Furthest object point: cube corner at |x|=0.325 m, |y|=0.205 m - both inside frame.

      FIX 3 - Consistent naming across all three sensors:
        depth   -> name="depth_camera1",   topic="depth_camera"
        rgb     -> name="rgb_camera",      topic="rgb_camera"
        semantic-> name="semantic_camera", topic="semantic_camera", segmentation_type=semantic
    -->
    <model name="depth_camera">
      <static>true</static>
      <self_collide>false</self_collide>
      <pose>0 -0.5 1.57 0 1.5708 0</pose>
      <link name="link">
        <pose>0.05 0.05 0.05 0 0 0</pose>
        <inertial>
          <mass>0.1</mass>
          <inertia>
            <ixx>0.000166667</ixx><iyy>0.000166667</iyy><izz>0.000166667</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
          <pose>0 0 0 0 0 0</pose>
        </inertial>
        <collision name="collision">
          <geometry><box><size>0.1 0.1 0.1</size></box></geometry>
          <surface>
            <friction><ode/></friction>
            <bounce/>
            <contact/>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.1 0.1 0.1</size></box></geometry>
        </visual>

        <!-- Depth sensor — FIX 2: FOV 0.9 -> 1.2 rad -->
        <sensor name="depth_camera1" type="depth_camera">
          <pose>0 0 0 0 0 0</pose>
          <topic>depth_camera</topic>
          <update_rate>10</update_rate>
          <enable_metrics>false</enable_metrics>
          <camera>
            <horizontal_fov>1.2</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R_FLOAT32</format>
              <anti_aliasing>4</anti_aliasing>
            </image>
            <camera_info_topic>__default__</camera_info_topic>
            <trigger_topic></trigger_topic>
            <triggered>false</triggered>
            <clip><near>0.1</near><far>2</far></clip>
            <save enabled="false"><path>__default__</path></save>
            <visibility_mask>4294967295</visibility_mask>
            <noise><type>none</type><mean>0</mean><stddev>0</stddev></noise>
            <distortion>
              <k1>0</k1><k2>0</k2><k3>0</k3>
              <p1>0</p1><p2>0</p2>
              <center>0.5 0.5</center>
            </distortion>
            <lens>
              <type>stereographic</type>
              <scale_to_hfov>true</scale_to_hfov>
              <cutoff_angle>1.5707963267948966</cutoff_angle>
              <env_texture_size>256</env_texture_size>
            </lens>
            <optical_frame_id></optical_frame_id>
          </camera>
        </sensor>

        <!-- RGB sensor — FIX 2: FOV 0.9 -> 1.2 rad -->
        <sensor name="rgb_camera" type="camera">
          <pose>0 0 0 0 0 0</pose>
          <topic>rgb_camera</topic>
          <update_rate>10</update_rate>
          <enable_metrics>false</enable_metrics>
          <camera>
            <horizontal_fov>1.2</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>RGB_INT8</format>
              <anti_aliasing>4</anti_aliasing>
            </image>
            <camera_info_topic>__default__</camera_info_topic>
            <trigger_topic></trigger_topic>
            <triggered>false</triggered>
            <clip><near>0.1</near><far>2</far></clip>
            <save enabled="false"><path>__default__</path></save>
            <visibility_mask>4294967295</visibility_mask>
            <noise><type>none</type><mean>0</mean><stddev>0</stddev></noise>
            <distortion>
              <k1>0</k1><k2>0</k2><k3>0</k3>
              <p1>0</p1><p2>0</p2>
              <center>0.5 0.5</center>
            </distortion>
            <lens>
              <type>stereographic</type>
              <scale_to_hfov>true</scale_to_hfov>
              <cutoff_angle>1.5707963267948966</cutoff_angle>
              <env_texture_size>256</env_texture_size>
            </lens>
            <optical_frame_id></optical_frame_id>
          </camera>
        </sensor>

        <!--
          Semantic segmentation sensor
          FIX 2: FOV 0.9 -> 1.2 rad
          FIX 3: name/topic/type all consistent as "semantic_camera"
        -->
        <sensor name="semantic_camera" type="segmentation">
          <pose>0 0 0 0 0 0</pose>
          <topic>semantic_camera</topic>
          <always_on>true</always_on>
          <update_rate>10</update_rate>
          <camera>
            <segmentation_type>semantic</segmentation_type>
            <horizontal_fov>1.2</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>RGB_INT8</format>
              <anti_aliasing>4</anti_aliasing>
            </image>
            <clip>
              <near>0.1</near>
              <far>2.0</far>
            </clip>
          </camera>
        </sensor>

        <enable_wind>false</enable_wind>
      </link>
    </model>

  </world>
</sdf>