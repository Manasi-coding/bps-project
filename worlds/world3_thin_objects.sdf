    <!-- ==================== THIN OBJECTS ON EXPERIMENT TABLE ==================== -->
    <!--
      WORLD PURPOSE: evaluate thin structures and boundary preservation.
      Stresses monocular depth estimation on long, narrow objects via
      crossing pairs, close parallel objects, partial overlaps, and one
      object resting fully on another (pen on notebook).

      Tabletop face : z = 0.77 m
      Safe footprint: x in [-0.40, 0.40],  y in [-0.75, -0.25]
      (unchanged from world1_primitives.sdf; camera pose/FOV untouched)

      Relational placements implemented:
        - knife crosses spoon        (spoon raised ~3mm above knife plane)
        - fork rests beside plate
        - pen rests on top of notebook (the one support relation)
        - cable crosses ruler         (cable raised to ruler-top height at crossing)
        - toothbrush touches mug      (tip exactly at mug radius)
        - bottle rests beside plate
        - chopsticks lie as a close parallel pair
        - straw, pencil placed in open clutter areas

      15 model instances covering the 14 requested object types
      (chopsticks realized as two parallel sticks, both label=13).
    -->

    <!-- PLATE  label=1 -->
    <model name="obj_plate">
      <static>true</static>
      <pose>0 -0.62 0.7775 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>0.11</radius><length>0.015</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.11</radius><length>0.015</length></cylinder></geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.85 0.85 0.85 1</diffuse>
            <specular>0.3 0.3 0.3 1</specular>
          </material>
          <plugin filename="gz-sim-label-system" name="gz::sim::systems::Label">
            <label>1</label>
          </plugin>
        </visual>
      </link>
    </model>

    <!-- FORK  label=2  (beside plate) -->
