    <!-- KNIFE  label=9  (crosses spoon) -->
    <model name="obj_knife">
      <static>true</static>
      <pose>-0.10 -0.36 0.7725 0 0 0.5</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.20 0.022 0.005</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.20 0.022 0.005</size></box></geometry>
          <material>
            <ambient>0.75 0.75 0.78 1</ambient>
            <diffuse>0.75 0.75 0.78 1</diffuse>
            <specular>0.6 0.6 0.6 1</specular>
          </material>
